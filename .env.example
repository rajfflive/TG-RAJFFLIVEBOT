# ==================== USERBOT API (main.py) ====================

# Telegram App credentials (get from my.telegram.org)
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Main API access key (for /api endpoint)
API_KEY=your_api_key_here

# Admin panel master key (for /admin endpoints)
ADMIN_KEY=your_strong_admin_key_here

# Bot username shown in all responses
BOT_USERNAME=@RAJFFLIVEBOT

# ── String Sessions (up to 5 accounts) ──
# All sessions use API_ID / API_HASH above by default.
# To use different Telegram app per session, set API_ID_2/API_HASH_2 etc.

STRING_SESSION=your_telethon_session_1_here
STRING_SESSION_2=your_telethon_session_2_here
STRING_SESSION_3=your_telethon_session_3_here
STRING_SESSION_4=your_telethon_session_4_here
STRING_SESSION_5=your_telethon_session_5_here

# Per-session overrides (optional — only if each account uses a different Telegram app)
# API_ID_2=
# API_HASH_2=
# API_ID_3=
# API_HASH_3=

# DB file path (optional)
DB_PATH=rajff.db

# Optional: external lookup API keys
# USERID_API_KEY=
# FELIX_API_KEY=

# ==================== TELEGRAM BOT (bot.py) ====================

# Bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# URL of the running main.py API
API_URL=http://localhost:5000

# Admin Telegram user IDs (comma separated) who can use /setbotusername /stats
ADMIN_IDS=123456789,987654321
